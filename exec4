<!--

    4) Construir uma página PHP onde seja possível entrar com 3 números e
    mostrá-los em ordem decrescente (suponha números diferentes).

    3 2 1

-->
<?php 

    $num1 = @$_GET["nr1"];
    $num2 = @$_GET["nr2"];
    $num3 = @$_GET["nr3"];

    $order = array();

    if ($num1 >= $num2 && $num2 >= $num3 && $num1 >= $num3) {
        $order = array($num1, $num2, $num3);
    }elseif ($num1 <= $num2 && $num2 <= $num3 && $num1 <= $num3) {
        $order = array($num3, $num2, $num1);
    }elseif ($num1 >= $num2 && $num2 <= $num3) {
        $order = array($num1,$num3,$num2);
    }elseif($num1 <= $num2){
        $order = array($num2,$num1,$num3);
    }elseif($num2 <= $num3){
        $order = array($num1,$num3,$num2);
    }else {
        $order = array($num1, $num2, $num3);
    }

?>

