<!--

    4) Construir uma página PHP onde seja possível entrar com 3 números e
    mostrá-los em ordem decrescente (suponha números diferentes).

    3 2 1

-->
<?php 
    $num1 = @$_GET["nr1"];
    $num2 = @$_GET["nr2"];
    $num3 = @$_GET["nr3"];
    $aux = 0;

    $order = array($num1,$num2,$num3);

    while(true){
        if ($num1 >= $num2) {
            $aux = $order[0];
            $order[0] = $num2;
            $order[1] = $aux;
        }elseif ($num2 >= $num3) {
            $aux = $order[1];
            $order[1] = $num3;
            $order[2] = $aux;
        }elseif ($num1 >= $num3) {
            $aux = $order[0];
            $order[0] = $num3;
            $order[2] = $aux;
        }else{
            break;
        }
    }
?>

