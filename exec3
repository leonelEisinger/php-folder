<!-- 

    3)Construir uma página PHP onde seja possível entrar com nome, sexo e
    idade de uma pessoa. Se a pessoa for do sexo feminino e tiver menos que 25
    anos, mostrar nome e a a mensagem: ACEITA. Caso contrário, mostrar nome e
    a mensagem: NÃO ACEITA.

-->

<?php 
    $nome = @$_GET["nome"];
    $sexo = @$_GET["sexo"];
    $idade = @$_GET["idade"];

    $result = "";

    if ($nome != null && $idade != null && $sexo != null) {
        if ($sexo == "Feminino" && $idade < 25){
            $result = $nome." - ACEITA";
        } else {
            $result = $nome." - NÃO ACEITA";
        }
    }
?>

